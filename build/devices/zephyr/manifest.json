{
	"include": [
		"$(MODULES)/files/preference/manifest.json"
	],
	"modules": {
		"*": [
			"$(MODULES)/base/time/*",
			"$(MODULES)/base/time/zephyr/*",
			"$(MODULES)/base/timer/*",
			"$(MODULES)/base/timer/mc/*"
		]
	},
	"creation": {
		"static": 131072,
		"chunk": {
			"initial": 2048,
			"incremental": 512
		},
		"heap": {
			"initial": 4096,
			"incremental": 256
		},
		"stack": 4096
	},
	"preload": [
		"timer",
		"time"
	],
	"platforms": {
		"zephyr/*": {
			"include": "$(BUILD)/devices/zephyr/targets/$(SUBPLATFORM)/manifest.json"
		}
	}
}
